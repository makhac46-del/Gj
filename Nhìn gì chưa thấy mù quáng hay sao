	MakeForm(BLOOD, "Ball")
	local bv = Instance.new("BodyVelocity", BLOOD)
	bv.maxForce = Vector3.new(1000000000, 1000000000, 1000000000)
	bv.velocity = CF(POSITION, DIRECTION + VT(MRANDOM(-3, 3) / 30, MRANDOM(-3, 3) / 30, MRANDOM(-3, 3) / 30)).lookVector * 25
	bv.Name = "MOVE"
